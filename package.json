{
  "name": "homebrew-tap-update-action",
  "version": "1.0.0",
  "description": "GitHub Action to update Homebrew formulas for macOS and Linux",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts --license licenses.txt",
    "prepare": "npm run build",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "keywords": ["github", "action", "homebrew", "tap", "formula"],
  "author": "Vincent Rischmann",
  "license": "MIT",
  "devDependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@types/node": "^20.14.10",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "axios": "^1.7.2"
  }
}